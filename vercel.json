{
  "version": 2,
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.9.0" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "uploads/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "src": "/(.*\\.php)", "dest": "/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
